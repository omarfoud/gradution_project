# =============================
# AI Backend Environment
# SmarterASP.NET (site4now) + FAISS + Gemini
# =============================

# Gemini - requires SDK >=0.8.0 for Gemini 2.x models
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Hosted SQL Server (SmarterASP.NET / site4now)
SQL_SERVER=SQL9001.site4now.net
SQL_PORT=1433
SQL_DATABASE=your_database_name
SQL_USERNAME=your_sql_username
SQL_PASSWORD=your_sql_password
SQL_DRIVER=ODBC Driver 18 for SQL Server

# Table names
SQL_TABLE_APPLICANT=Applicants
SQL_TABLE_RESUME=Resumes
SQL_TABLE_COMPANY=Companies
SQL_TABLE_JOB_POSTING=JobPostings
SQL_TABLE_APPLICATION=Applications

# Resume file handling
REQUIRE_REMOTE_RESUME_URL=true

# CORS
ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------
# Search Artifact Storage
# Docker auto-downloads jobs.db and jobs.index on first startup.
# Hugging Face is the recommended artifact host.
# -----------------------------------------------------------------------
HF_REPO_ID=omaralifouda/jobify-artifacts
HF_REPO_TYPE=dataset
HF_TOKEN=your_huggingface_read_token
HF_DB_FILENAME=jobs.db
HF_INDEX_FILENAME=jobs.index
HF_ARTIFACT_DIR=/app/artifacts
# For non-Docker local runs, you can use:
# HF_ARTIFACT_DIR=artifacts

# Optional fallback: any direct HTTPS URL. Leave blank when using Hugging Face.
ARTIFACTS_URL_DB=
ARTIFACTS_URL_INDEX=

# Local AI search paths inside the container - do not change for Docker.
CSV_PATH=job_descriptions.csv
DB_PATH=/app/artifacts/jobs.db
INDEX_PATH=/app/artifacts/jobs.index

# Embedding model
MODEL_NAME=all-MiniLM-L6-v2
DEVICE=cpu

# Logging
LOG_LEVEL=INFO

# Search settings
FAISS_TOP_K=500
FAISS_NPROBE=20
SQL_BATCH_SIZE=900
RESULTS_LIMIT=10
MAX_CV_CHARS=4000
REQUEST_TIMEOUT_SECONDS=20

# Ingestion settings (only needed when running ingest.py locally)
CHUNK_SIZE=5000
BATCH_SIZE=64
FAISS_NLIST=1000
RESET_DB=false

# Security
REQUIRE_AUTH=false
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ADMIN_API_KEY=change-this-to-a-long-random-string

# After the main backend inserts a new SQL Server job posting, call:
# POST /admin/sync-job-embedding
# Headers: X-Admin-API-Key: <ADMIN_API_KEY>
# Body: {"job_posting_id":"123","company_id":"45"}
