# =============================
# AI Backend Environment
# SmarterASP.NET (site4now) + FAISS + Gemini
# =============================

# Gemini — requires SDK >=0.8.0 for Gemini 2.x models
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Hosted SQL Server (SmarterASP.NET / site4now)
SQL_SERVER=SQL9001.site4now.net
SQL_PORT=1433
SQL_DATABASE=your_database_name
SQL_USERNAME=your_sql_username
SQL_PASSWORD=your_sql_password
SQL_DRIVER=ODBC Driver 18 for SQL Server

# Table names
SQL_TABLE_APPLICANT=Applicants
SQL_TABLE_RESUME=Resumes
SQL_TABLE_COMPANY=Companies
SQL_TABLE_JOB_POSTING=JobPostings
SQL_TABLE_APPLICATION=Applications

# Resume file handling
REQUIRE_REMOTE_RESUME_URL=true

# CORS
ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------
# Search Artifact Storage
# Run python ingest.py ONCE locally → generates jobs.db and jobs.index
# Then host them using ONE of the options below:
#
# OPTION A — Hugging Face (FREE, recommended for graduation project)
#   1. Create free account at huggingface.co
#   2. Create a private dataset repo (e.g. your-username/jobify-artifacts)
#   3. Get a token from huggingface.co/settings/tokens  (role: write)
#   4. Upload:
#        pip install huggingface_hub
#        python -c "
#        from huggingface_hub import HfApi
#        api = HfApi()
#        api.upload_file('jobs.db',    'jobs.db',    'YOUR_USERNAME/jobify-artifacts', repo_type='dataset', token='YOUR_TOKEN')
#        api.upload_file('jobs.index', 'jobs.index', 'YOUR_USERNAME/jobify-artifacts', repo_type='dataset', token='YOUR_TOKEN')
#        "
#   5. Fill HF_REPO_ID and HF_TOKEN below
# -----------------------------------------------------------------------
HF_REPO_ID=your-hf-username/jobify-artifacts
HF_TOKEN=hf_your_token_here

# OPTION B — Any direct HTTPS URL (leave blank if using Option A)
ARTIFACTS_URL_DB=
ARTIFACTS_URL_INDEX=

# -----------------------------------------------------------------------
# Local AI search paths (inside the container — do not change)
# -----------------------------------------------------------------------
CSV_PATH=job_descriptions.csv
DB_PATH=jobs.db
INDEX_PATH=jobs.index

# Embedding model
MODEL_NAME=all-MiniLM-L6-v2
DEVICE=cpu

# Logging
LOG_LEVEL=INFO

# Search settings
FAISS_TOP_K=500
FAISS_NPROBE=20
SQL_BATCH_SIZE=900
RESULTS_LIMIT=10
MAX_CV_CHARS=4000
REQUEST_TIMEOUT_SECONDS=20

# Ingestion settings (only needed when running ingest.py locally)
CHUNK_SIZE=5000
BATCH_SIZE=64
FAISS_NLIST=1000
RESET_DB=false

# Security
REQUIRE_AUTH=false
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ADMIN_API_KEY=change-this-to-a-long-random-string
