# =============================
# AI Backend Environment Example
# Hosted SQL Server + FAISS + Gemini
# =============================

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Hosted SQL Server Database
# Example: SQL9001.site4now.net
SQL_SERVER=SQL9001.site4now.net
SQL_PORT=1433
SQL_DATABASE=your_database_name
SQL_USERNAME=your_sql_username
SQL_PASSWORD=your_sql_password
SQL_DRIVER=ODBC Driver 18 for SQL Server

# Main application table names
# Keep these plural for the current Site4Now database.
# If another database uses singular ERD names, set them to Applicant, Resume, Company, JobPosting, Application.
SQL_TABLE_APPLICANT=Applicants
SQL_TABLE_RESUME=Resumes
SQL_TABLE_COMPANY=Companies
SQL_TABLE_JOB_POSTING=JobPostings
SQL_TABLE_APPLICATION=Applications

# Resume file handling
# In production, Resume.FilePath should be a public/signed URL to PDF or DOCX.
REQUIRE_REMOTE_RESUME_URL=true

# CORS
ALLOWED_ORIGINS=*

# Local AI search storage
CSV_PATH=job_descriptions.csv
DB_PATH=jobs.db
INDEX_PATH=jobs.index

# Embedding model
MODEL_NAME=all-MiniLM-L6-v2
DEVICE=cpu

# Logging
LOG_LEVEL=INFO

# Search settings
FAISS_TOP_K=500
FAISS_NPROBE=20
SQL_BATCH_SIZE=900
RESULTS_LIMIT=10
MAX_CV_CHARS=4000
REQUEST_TIMEOUT_SECONDS=20

# Ingestion settings
CHUNK_SIZE=5000
BATCH_SIZE=64
FAISS_NLIST=1000
RESET_DB=true
