# =============================
# AI Backend Environment
# Azure SQL + FAISS + Gemini
# =============================

# Gemini — MUST be >=0.8.0 SDK to support Gemini 2.x models
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Hosted SQL Server Database
SQL_SERVER=SQL9001.site4now.net
SQL_PORT=1433
SQL_DATABASE=your_database_name
SQL_USERNAME=your_sql_username
SQL_PASSWORD=your_sql_password
SQL_DRIVER=ODBC Driver 18 for SQL Server

# Table names — set to singular if your DB uses ERD-style names
SQL_TABLE_APPLICANT=Applicants
SQL_TABLE_RESUME=Resumes
SQL_TABLE_COMPANY=Companies
SQL_TABLE_JOB_POSTING=JobPostings
SQL_TABLE_APPLICATION=Applications

# Resume file handling
REQUIRE_REMOTE_RESUME_URL=true

# CORS
ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------
# Search artifact storage (Azure Blob Storage SAS URLs)
# Run python ingest.py ONCE locally to generate jobs.db and jobs.index,
# then upload them to an Azure Blob container and paste the SAS URLs here.
# The container will auto-download them on startup if they are missing.
# Leave empty to use volume mounts (local dev) or baked-in files.
# -----------------------------------------------------------------------
ARTIFACTS_URL_DB=
ARTIFACTS_URL_INDEX=

# Local AI search storage paths inside the container
CSV_PATH=job_descriptions.csv
DB_PATH=jobs.db
INDEX_PATH=jobs.index

# Embedding model
MODEL_NAME=all-MiniLM-L6-v2
DEVICE=cpu

# Logging
LOG_LEVEL=INFO

# Search settings
FAISS_TOP_K=500
FAISS_NPROBE=20
SQL_BATCH_SIZE=900
RESULTS_LIMIT=10
MAX_CV_CHARS=4000
REQUEST_TIMEOUT_SECONDS=20

# Ingestion settings (only needed when running ingest.py)
CHUNK_SIZE=5000
BATCH_SIZE=64
FAISS_NLIST=1000
RESET_DB=false

# Auth (optional — set REQUIRE_AUTH=true and configure JWT to enforce auth)
REQUIRE_AUTH=false
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256

# Cache admin key — set this to protect /clear-cache endpoint
ADMIN_API_KEY=change-this-to-a-secure-random-string
